// prisma/schema.prisma
// E-Prescription System — Kazakhstan MVP
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────

enum UserRole {
  doctor
  pharmacist
  admin
  super_admin
}

enum AccountStatus {
  pending
  active
  suspended
}

enum PrescriptionStatus {
  created
  active
  partially_dispensed
  dispensed
  cancelled
  expired
}

enum MedicationForm {
  tablets
  capsules
  ampoules
  syrup
  drops
  ointment
  injection
  other
}

// ─── USERS ───────────────────────────────────

model User {
  id              String        @id @default(uuid())
  fullName        String
  email           String        @unique
  phone           String
  passwordHash    String
  role            UserRole
  accountStatus   AccountStatus @default(pending)
  activationToken String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?

  createdBy      User?           @relation("AdminCreatedUsers", fields: [createdById], references: [id])
  createdUsers   User[]          @relation("AdminCreatedUsers")
  prescriptions  Prescription[]  @relation("DoctorPrescriptions")
  dispenseEvents DispenseEvent[]
  auditLogs      AuditLog[]

  @@map("users")
}

// ─── PATIENTS ────────────────────────────────

model Patient {
  id            String         @id @default(uuid())
  fullName      String
  iin           String
  phone         String
  email         String
  createdAt     DateTime       @default(now())
  prescriptions Prescription[]

  @@index([iin])
  @@map("patients")
}

// ─── PRESCRIPTIONS ───────────────────────────

model Prescription {
  id           String             @id @default(cuid())
  patientId    String
  doctorId     String
  status       PrescriptionStatus @default(created)
  createdAt    DateTime           @default(now())
  expiresAt    DateTime
  cancelledAt  DateTime?
  cancelReason String?

  patient        Patient            @relation(fields: [patientId], references: [id])
  doctor         User               @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  medications    PrescriptionItem[]
  dispenseEvents DispenseEvent[]
  auditLogs      AuditLog[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("prescriptions")
}

// ─── PRESCRIPTION ITEMS ──────────────────────

model PrescriptionItem {
  id             String         @id @default(uuid())
  prescriptionId String
  name           String
  form           MedicationForm
  dosage         String
  qtyPrescribed  Int
  qtyDispensed   Int            @default(0)
  course         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  prescription  Prescription   @relation(fields: [prescriptionId], references: [id])
  dispenseItems DispenseItem[]

  @@map("prescription_items")
}

// ─── DISPENSE EVENTS ─────────────────────────

model DispenseEvent {
  id             String   @id @default(uuid())
  prescriptionId String
  pharmacistId   String
  timestamp      DateTime @default(now())
  note           String?

  prescription Prescription  @relation(fields: [prescriptionId], references: [id])
  pharmacist   User          @relation(fields: [pharmacistId], references: [id])
  items        DispenseItem[]

  @@index([prescriptionId])
  @@map("dispense_events")
}

// ─── DISPENSE ITEMS ──────────────────────────

model DispenseItem {
  id              String @id @default(uuid())
  dispenseEventId String
  itemId          String
  qtyDispensed    Int

  dispenseEvent DispenseEvent    @relation(fields: [dispenseEventId], references: [id])
  item          PrescriptionItem @relation(fields: [itemId], references: [id])

  @@map("dispense_items")
}

// ─── AUDIT LOGS ──────────────────────────────

model AuditLog {
  id             String    @id @default(uuid())
  userId         String
  action         String
  entityType     String
  entityId       String
  details        String
  timestamp      DateTime  @default(now())
  prescriptionId String?

  user         User          @relation(fields: [userId], references: [id])
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
